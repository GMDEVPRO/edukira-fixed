# ════════════════════════════════════════════════════
# Edukira Frontend — Variables d'environnement
# Copiez ce fichier en .env.local pour le développement
# ════════════════════════════════════════════════════

# ── API Backend ──────────────────────────────────────
# URL du serveur Spring Boot (SANS /api — ajouté automatiquement)
# Développement local:
VITE_API_URL=http://localhost:8080
# Production:
# VITE_API_URL=https://api.edukira.com

# ── WhatsApp Support ─────────────────────────────────
# Numéro WhatsApp du support (format international sans +)
VITE_WHATSAPP_NUMBER=221771234567

# ── Monitoring (optionnel) ───────────────────────────
# Sentry DSN pour la capture d'erreurs en production
# VITE_SENTRY_DSN=https://xxx@sentry.io/xxx

# ── Analytics (optionnel) ────────────────────────────
# Google Tag Manager ID
# VITE_GTM_ID=GTM-XXXXXXX
